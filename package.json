{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://mrgkumar.github.io/sanskrit-keyboard",
  "scripts": {
    "predev": "node scripts/copyAutocompleteAssets.mjs",
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "prebuild": "node scripts/copyAutocompleteAssets.mjs",
    "build": "next build",
    "start": "node scripts/serve-static-export.mjs",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d out",
    "lint": "eslint",
    "build:canonical-lexicon": "node --experimental-strip-types scripts/buildCanonicalLexicon.ts",
    "build:canonical-lexicon:sample": "node --experimental-strip-types scripts/buildCanonicalLexicon.ts --limit 2000",
    "build:runtime-lexicon": "node --experimental-strip-types scripts/buildRuntimeLexicon.ts",
    "build:runtime-lexicon:sample": "node --experimental-strip-types scripts/buildRuntimeLexicon.ts --limit 20000",
    "build:swara-lexicon": "node --experimental-strip-types scripts/buildSwaraLexicon.ts",
    "build:completion-training-data": "node --experimental-strip-types scripts/buildCompletionTrainingData.ts",
    "build:prediction-corpus": "node --experimental-strip-types scripts/rebuildPredictionCorpus.ts",
    "build:prediction-corpus:sample": "node --experimental-strip-types scripts/rebuildPredictionCorpus.ts --canonical-limit 2000 --runtime-limit 20000 --swara-limit 4000",
    "evaluate:prediction-corpus": "node --experimental-strip-types scripts/evaluatePredictionCorpus.ts --output ../generated/autocomplete/prediction-eval.json",
    "evaluate:prediction-retrieval": "node --experimental-strip-types scripts/evaluatePredictionRetrieval.ts",
    "analyze:prediction-retrieval-gaps": "node --experimental-strip-types scripts/analyzePredictionRetrievalGaps.ts",
    "analyze:prediction-retrieval-taxonomy": "node --experimental-strip-types scripts/analyzePredictionRetrievalMissTaxonomy.ts",
    "evaluate:prediction-experiments": "node --experimental-strip-types scripts/runPredictionExperimentGame.ts",
    "prepare:prediction-datasets": "node --experimental-strip-types scripts/preparePredictionDataset.ts",
    "evaluate:prediction-models": "python3 scripts/runProbabilisticPredictionGame.py",
    "evaluate:prediction-models:sanskrit": "python3 scripts/runSanskritPredictionGame.py",
    "evaluate:prediction-models:supervised": "python3 scripts/runSupervisedPredictionGame.py",
    "test:transliteration": "playwright test transliteration.spec.ts",
    "test:transliteration:forward": "playwright test transliteration.spec.ts --grep \"Forward\"",
    "test:transliteration:reverse": "playwright test transliteration.spec.ts --grep \"Reverse\"",
    "test-detransliterate": "npm run test:transliteration:reverse",
    "test-detransliterate-sampled": "npm run test:transliteration"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "lucide-react": "^1.0.1",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
