  {
    "text": "नित्य पारायण श्लोकाः (26)",
    "href": "https://vignanam.org/devanagari.html"
  },
  {
    "text": "गणपति प्रार्थन घनपाठः",
    "href": "https://vignanam.org/devanagari/ganapati-prarthana-ghanapatham.html"
  },
  {
    "text": "गायत्री मन्त्रं घनपाठः",
    "href": "https://vignanam.org/devanagari/gayatri-mantram-ghanapatham.html"
  },
  {
    "text": "पुरुष सूक्तम्",
    "href": "https://vignanam.org/devanagari/purusha-suktam.html"
  },
  {
    "text": "नारायण सूक्तम्",
    "href": "https://vignanam.org/devanagari/narayana-suktam.html"
  },
  {
    "text": "मन्त्र पुष्पम्",
    "href": "https://vignanam.org/devanagari/mantra-pushpam.html"
  },
  {
    "text": "नित्य पारायण श्लोकाः",
    "href": "https://vignanam.org/devanagari/nitya-parayana-slokas.html"
  },
  {
    "text": "नित्य सन्ध्या वन्दनम् (कृष्ण यजुर्वेदीय)",
    "href": "https://vignanam.org/devanagari/nitya-sandhya-vandanam-krishna-yajurvediya.html"
  },
  {
    "text": "शिव मानस पूज",
    "href": "https://vignanam.org/devanagari/shiva-manasa-puja.html"
  },
  {
    "text": "रामायण जय मन्त्रम्",
    "href": "https://vignanam.org/devanagari/ramayana-jaya-mantram.html"
  },
  {
    "text": "वातापि गणपतिं भजेहं",
    "href": "https://vignanam.org/devanagari/vatapi-ganapatim-bhajeham.html"
  },
  {
    "text": "श्री हयग्रीव स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/sri-hayagriva-stotram.html"
  },
  {
    "text": "यज्ञोपवीत धारण",
    "href": "https://vignanam.org/devanagari/yagnopavita-dharana.html"
  },
  {
    "text": "सर्व देवता गायत्री मन्त्राः",
    "href": "https://vignanam.org/devanagari/sarva-devata-gayatri-mantras.html"
  },
  {
    "text": "महागणपतिं मनसा स्मरामि",
    "href": "https://vignanam.org/devanagari/mahaganapatim-manasa-smarami.html"
  },
  {
    "text": "विश्वकर्म सूक्तम्",
    "href": "https://vignanam.org/devanagari/vishwakarma-suktam.html"
  },
  {
    "text": "अग्नि सूक्तम् (ऋग्वेद)",
    "href": "https://vignanam.org/devanagari/agni-suktam-rugveda.html"
  },
  {
    "text": "क्रिमि संहारक सूक्तम् (यजुर्वेद)",
    "href": "https://vignanam.org/devanagari/krimi-samharaka-suktam-yajurveda.html"
  },
  {
    "text": "नीला सूक्तम्",
    "href": "https://vignanam.org/devanagari/neela-suktam.html"
  },
  {
    "text": "वेद आशीर्वचनम्",
    "href": "https://vignanam.org/devanagari/veda-asheervachanam.html"
  },
  {
    "text": "वेद स्वस्ति वाचनम्",
    "href": "https://vignanam.org/devanagari/veda-svasti-vachanam.html"
  },
  {
    "text": "ऐकमत्य सूक्तम् (ऋग्वेद)",
    "href": "https://vignanam.org/devanagari/aikamatya-suktam.html"
  },
  {
    "text": "श्री हयग्रीव सम्पदा स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/sri-hayagriva-sampada-stotram.html"
  },
  {
    "text": "श्री गणेश (गणपति) सूक्तम् (ऋग्वेद)",
    "href": "https://vignanam.org/devanagari/sri-ganesha-ganapati-suktam.html"
  },
  {
    "text": "शुक्ल यजुर्वेद सन्ध्यावन्दनम्",
    "href": "https://vignanam.org/devanagari/shukla-yajurveda-sandhya-vandanam.html"
  },
  {
    "text": "ऋग्वेद सन्ध्यावन्दनम्",
    "href": "https://vignanam.org/devanagari/rigveda-sandhya-vandanam.html"
  },
  {
    "text": "एकात्मता स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/ekatmata-stotram.html"
  },
  {
    "text": "वेद मन्त्राः (87)",
    "href": "https://vignanam.org/devanagari.html"
  },
  {
    "text": "गणपति प्रार्थन घनपाठः",
    "href": "https://vignanam.org/devanagari/ganapati-prarthana-ghanapatham.html"
  },
  {
    "text": "गायत्री मन्त्रं घनपाठः",
    "href": "https://vignanam.org/devanagari/gayatri-mantram-ghanapatham.html"
  },
  {
    "text": "श्री रुद्रं लघुन्यासम्",
    "href": "https://vignanam.org/devanagari/sri-rudram-laghunyasam.html"
  },
  {
    "text": "श्री रुद्रं नमकम्",
    "href": "https://vignanam.org/devanagari/sri-rudram-namakam.html"
  },
  {
    "text": "श्री रुद्रं - चमकप्रश्नः",
    "href": "https://vignanam.org/devanagari/sri-rudram-chamakam.html"
  },
  {
    "text": "पुरुष सूक्तम्",
    "href": "https://vignanam.org/devanagari/purusha-suktam.html"
  },
  {
    "text": "श्री सूक्तम्",
    "href": "https://vignanam.org/devanagari/sri-suktam.html"
  },
  {
    "text": "दुर्गा सूक्तम्",
    "href": "https://vignanam.org/devanagari/durga-suktam.html"
  },
  {
    "text": "नारायण सूक्तम्",
    "href": "https://vignanam.org/devanagari/narayana-suktam.html"
  },
  {
    "text": "मन्त्र पुष्पम्",
    "href": "https://vignanam.org/devanagari/mantra-pushpam.html"
  },
  {
    "text": "शान्ति मन्त्रम् (दश शान्तयः)",
    "href": "https://vignanam.org/devanagari/shanti-mantram-dasha-shanti-mantram.html"
  },
  {
    "text": "नित्य सन्ध्या वन्दनम् (कृष्ण यजुर्वेदीय)",
    "href": "https://vignanam.org/devanagari/nitya-sandhya-vandanam-krishna-yajurvediya.html"
  },
  {
    "text": "श्री गणपति अथर्व षीर्षम् (गणपत्यथर्वषीर्षोपनिषत्)",
    "href": "https://vignanam.org/devanagari/ganapati-atharva-sheersham.html"
  },
  {
    "text": "ईशावास्योपनिषद् (ईशोपनिषद्)",
    "href": "https://vignanam.org/devanagari/eesavasyopanishad-ishopanishad.html"
  },
  {
    "text": "नक्षत्र सूक्तम् (नक्षत्रेष्टि)",
    "href": "https://vignanam.org/devanagari/nakshatra-suktam-nakshatreshti.html"
  },
  {
    "text": "मन्यु सूक्तम्",
    "href": "https://vignanam.org/devanagari/manyu-suktam.html"
  },
  {
    "text": "मेधा सूक्तम्",
    "href": "https://vignanam.org/devanagari/medha-suktam.html"
  },
  {
    "text": "विष्णु सूक्तम्",
    "href": "https://vignanam.org/devanagari/vishnu-suktam.html"
  },
  {
    "text": "शिव पञ्चामृत स्नानाभिषेकम्",
    "href": "https://vignanam.org/devanagari/shiva-panchamruta-snanam.html"
  },
  {
    "text": "यज्ञोपवीत धारण",
    "href": "https://vignanam.org/devanagari/yagnopavita-dharana.html"
  },
  {
    "text": "सर्व देवता गायत्री मन्त्राः",
    "href": "https://vignanam.org/devanagari/sarva-devata-gayatri-mantras.html"
  },
  {
    "text": "तैत्तिरीय उपनिषद् - शीक्षावल्ली",
    "href": "https://vignanam.org/devanagari/taittiriya-upanishad-shiksha-valli.html"
  },
  {
    "text": "तैत्तिरीय उपनिषद् - आनन्दवल्ली",
    "href": "https://vignanam.org/devanagari/taittiriya-upanishad-ananda-valli.html"
  },
  {
    "text": "तैत्तिरीय उपनिषद् - भृगुवल्ली",
    "href": "https://vignanam.org/devanagari/taittiriya-upanishad-bhrugu-valli.html"
  },
  {
    "text": "भू सूक्तम्",
    "href": "https://vignanam.org/devanagari/bhu-suktam.html"
  },
  {
    "text": "नवग्रह सूक्तम्",
    "href": "https://vignanam.org/devanagari/navagraha-suktam.html"
  },
  {
    "text": "महानारायण उपनिषद्",
    "href": "https://vignanam.org/devanagari/maha-narayana-upanishad.html"
  },
  {
    "text": "अरुणप्रश्नः",
    "href": "https://vignanam.org/devanagari/aruna-prasna.html"
  },
  {
    "text": "श्री महान्यासम्",
    "href": "https://vignanam.org/devanagari/mahanyasam.html"
  },
  {
    "text": "सरस्वती सूक्तम्",
    "href": "https://vignanam.org/devanagari/saraswati-suktam.html"
  },
  {
    "text": "भाग्य सूक्तम्",
    "href": "https://vignanam.org/devanagari/bhagya-suktam.html"
  },
  {
    "text": "पवमान सूक्तम्",
    "href": "https://vignanam.org/devanagari/pavamana-suktam.html"
  },
  {
    "text": "नासदीय सूक्तम्",
    "href": "https://vignanam.org/devanagari/nasadiya-suktam.html"
  },
  {
    "text": "नवग्रह सूक्तम्",
    "href": "https://vignanam.org/devanagari/navagraha-suktam.html"
  },
  {
    "text": "पितृ सूक्तम्",
    "href": "https://vignanam.org/devanagari/pitru-suktam.html"
  },
  {
    "text": "रात्रि सूक्तम्",
    "href": "https://vignanam.org/devanagari/ratri-suktam.html"
  },
  {
    "text": "सर्प सूक्तम्",
    "href": "https://vignanam.org/devanagari/sarpa-suktam.html"
  },
  {
    "text": "हिरण्य गर्भ सूक्तम्",
    "href": "https://vignanam.org/devanagari/hiranya-garbha-suktam.html"
  }
]