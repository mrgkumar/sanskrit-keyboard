    "text": "तोटकाष्टकम्",
    "href": "https://vignanam.org/devanagari/totakashtakam.html"
  },
  {
    "text": "शिव मानस पूज",
    "href": "https://vignanam.org/devanagari/shiva-manasa-puja.html"
  },
  {
    "text": "शिव सहस्र नाम स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-sahasra-nama-stotram.html"
  },
  {
    "text": "उमा महेश्वर स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/uma-maheswara-stotram.html"
  },
  {
    "text": "शिव अष्टोत्तर शत नाम स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-ashtottara-sata-nama-stotram.html"
  },
  {
    "text": "शिव ताण्डव स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-tandava-stotram.html"
  },
  {
    "text": "शिव भुजङ्ग स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-bhujanga-stotram.html"
  },
  {
    "text": "द्वादश ज्योतिर्लिङ्ग स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/dwadasa-jyotirlinga-stotram.html"
  },
  {
    "text": "अर्ध नारीश्वर अष्टकम्",
    "href": "https://vignanam.org/devanagari/ardha-naareeswara-ashtakam.html"
  },
  {
    "text": "शिव कवचम्",
    "href": "https://vignanam.org/devanagari/shiva-kavacham.html"
  },
  {
    "text": "शिव महिम्ना स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-mahimna-stotram.html"
  },
  {
    "text": "श्री काल हस्तीश्वर शतकम्(तॆलुगु)",
    "href": "https://vignanam.org/devanagari/sree-kaala-hastiswara-satakam-telugu.html"
  },
  {
    "text": "शिव मङ्गलाष्टकम्",
    "href": "https://vignanam.org/devanagari/shiva-mangalashtakam.html"
  },
  {
    "text": "श्री मल्लिकार्जुन मङ्गलाशासनम्",
    "href": "https://vignanam.org/devanagari/sree-mallikarjuna-mangalasasanam.html"
  },
  {
    "text": "शिव षडक्षरी स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-shadakshari-stotram.html"
  },
  {
    "text": "शिव पञ्चायतन षोडश उपचार पुज",
    "href": "https://vignanam.org/devanagari/shiva-panchayatana-shodasa-upachara-puja.html"
  },
  {
    "text": "शिवापराध क्षमापण स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-aparadha-kshamapana-stotram.html"
  },
  {
    "text": "दारिद्र्य दहन शिव स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/daridrya-dahana-shiva-stotram.html"
  },
  {
    "text": "शिव भुजङ्ग प्रयात स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/shiva-bhujanga-prayata-stotram.html"
  },
  {
    "text": "अर्ध नारीश्वर स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/ardha-nareeswara-stotram.html"
  },
  {
    "text": "महामृत्युञ्जय स्तोत्रम् (रुद्रं पशुपतिम्)",
    "href": "https://vignanam.org/devanagari/maha-mrutyunjaya-stotram-rudram-pasupatim.html"
  },
  {
    "text": "श्री काशी विश्वनाथ स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/sri-kashi-viswanatha-stotram.html"
  },
  {
    "text": "द्वादश ज्योतिर्लिङ्ग स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/dvadasha-jyothirlinga-stotram.html"
  },
  {
    "text": "वैद्यनाथाष्टकम्",
    "href": "https://vignanam.org/devanagari/vaidyanatha-ashtakam.html"
  },
  {
    "text": "श्री शिव आरती",
    "href": "https://vignanam.org/devanagari/sri-shiva-aarati.html"
  },
  {
    "text": "नटराज स्तोत्रं (पतञ्जलि कृतम्)",
    "href": "https://vignanam.org/devanagari/nataraja-stotram-patanjali-krutam.html"
  },
  {
    "text": "श्री शिव चालीसा",
    "href": "https://vignanam.org/devanagari/sri-shiva-chalisa.html"
  },
  {
    "text": "श्री साम्ब सदाशिव अक्षरमाला स्तोत्रम् (मातृक वर्णमालिका स्तोत्रम्)",
    "href": "https://vignanam.org/devanagari/sri-samba-sadashiva-aksharamala-stotram-matruka-varnamalika-stotram.html"
  },
  {
    "text": "आनन्द लहरि",
    "href": "https://vignanam.org/devanagari/ananda-lahari.html"
  },
  {
    "text": "शत रुद्रीयम्",
    "href": "https://vignanam.org/devanagari/sata-rudreeyam.html"
  },
  {
    "text": "श्री स्वर्णाकर्षण भैरव अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-swarna-akarshana-bhairava-ashtottara-sata-namavali.html"
  },
  {
    "text": "शरभेशाष्टकम्",
    "href": "https://vignanam.org/devanagari/sharabhesha-ashtakam.html"
  },
  {
    "text": "श्री श्रीशैल मल्लिकार्जुन सुप्रभातम्",
    "href": "https://vignanam.org/devanagari/sri-srisaila-mallikarjuna-suprabhatam.html"
  },
  {
    "text": "पार्वती वल्लभ अष्टकम्",
    "href": "https://vignanam.org/devanagari/parvati-vallabha-ashtakam.html"
  },
  {
    "text": "श्री वीरभद्राष्टोत्तर शत नामावलिः",
    "href": "https://vignanam.org/devanagari/sri-veerabhadra-ashtottara-sata-namavali.html"
  },
  {
    "text": "अरुणाचल अष्टकम्",
    "href": "https://vignanam.org/devanagari/arunachala-ashtakam.html"
  },
  {
    "text": "अरुणाचल अक्षर मणि माला स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/arunachala-akshara-mani-mala-stotram.html"
  },
  {
    "text": "पशुपत्यष्टकम्",
    "href": "https://vignanam.org/devanagari/pashupati-ashtakam.html"
  },
  {
    "text": "श्रीशैल रगड (तॆलुगु)",
    "href": "https://vignanam.org/devanagari/srisaila-ragada-telugu.html"
  },
  {
    "text": "श्री शिव दण्डकम् (तॆलुगु)",
    "href": "https://vignanam.org/devanagari/sri-shiva-dandakam-telugu.html"
  },
  {
    "text": "श्री काल भैरव स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/sri-kala-bhairava-stotram.html"
  },
  {
    "text": "शिव सहस्र नामावलिः",
    "href": "https://vignanam.org/devanagari/shiva-sahasra-namavali.html"
  },
  {
    "text": "शिव सुवर्णमाला स्तुति",
    "href": "https://vignanam.org/devanagari/shiva-suvarnamala-swarnamala-stuti.html"
  },
  {
    "text": "यम कृत शिव केशव स्तोत्रं",
    "href": "https://vignanam.org/devanagari/yama-kruta-shiva-keshava-stotram.html"
  },
  {
    "text": "यम कृत शिव केशव अष्टोत्तर शत नामावलिः",
    "href": "https://vignanam.org/devanagari/yama-kruta-shiva-keshava-ashtottara-sata-namavali.html"
  },
  {
    "text": "काशी पञ्चकं",
    "href": "https://vignanam.org/devanagari/kashi-panchakam.html"
  },
  {
    "text": "निर्गुण मानस पूजा",
    "href": "https://vignanam.org/devanagari/nirguna-manasa-puja.html"
  },
  {
    "text": "शिव पादादि केशान्त वर्णन स्तोत्रं",
    "href": "https://vignanam.org/devanagari/shiva-padadi-keshanta-varnana-stotram.html"
  },
  {
    "text": "शिव केशादि पादान्त वर्णन स्तोत्रं",
    "href": "https://vignanam.org/devanagari/shiva-keshadi-padanta-varnana-stotram.html"
  },
  {
    "text": "शिव नामावल्यष्टकं (नामावली अष्टकं)",
    "href": "https://vignanam.org/devanagari/shiva-namavalyashtakam-namavali-ashtakam.html"
  },
  {
    "text": "श्री स्वर्ण आकर्षण भैरव स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/sri-swarna-akarshana-bhairava-stotram.html"
  },
  {
    "text": "श्री मेधा दक्षिणामूर्ति मन्त्रवर्णपद स्तुतिः",
    "href": "https://vignanam.org/devanagari/sri-medha-dakshina-murthy-stotram.html"
  },
  {
    "text": "तत्त्वबोध (आदि शङ्कराचार्य)",
    "href": "https://vignanam.org/devanagari/tattvabodha-adi-shankaracharya.html"
  },
  {
    "text": "श्री मृत्युञ्जय अष्टोत्तर शत नामावलिः",
    "href": "https://vignanam.org/devanagari/sri-mrutyunjaya-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री रुद्र कवचम्",
    "href": "https://vignanam.org/devanagari/sri-rudra-kavacham.html"
  },
  {
    "text": "दक्षिणामूर्थि द्वादश नाम स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/dakshina-murthy-dwadasha-nama-stotram.html"
  },
  {
    "text": "श्री महा कालभैरव कवचं",
    "href": "https://vignanam.org/devanagari/sri-maha-kalabhairava-kavacham.html"
  },
  {
    "text": "श्री बटुक भैरव कवचं",
    "href": "https://vignanam.org/devanagari/sri-batuka-bhairava-kavacham.html"
  },
  {
    "text": "श्री बटुक भैरव अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-batuka-bhairava-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री काशी विश्वनाथ सुप्राभातम्",
    "href": "https://vignanam.org/devanagari/sri-kashi-viswanatha-suprabhatam.html"
  },
  {
    "text": "गणेश अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/ganesha-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री वेङ्कटेश्वर अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/venkateswara-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री महा लक्ष्मी अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sree-maha-lakshmi-ashtottara-sata-naamaavali.html"
  },
  {
    "text": "हनुम अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/hanuman-ashtottara-sata-namavali.html"
  },
  {
    "text": "सायि बाबा अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sai-baba-ashtottara-sata-namavali.html"
  },
  {
    "text": "ललिता अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/lalitha-ashtottara-sata-namaavali.html"
  },
  {
    "text": "श्री रामाष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-rama-ashtottara-sata-namaavali.html"
  },
  {
    "text": "श्री कृष्णाष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-krishna-ashtottara-sata-namavali.html"
  },
  {
    "text": "सरस्वती अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/saraswati-ashtottara-sata-namavali.html"
  },
  {
    "text": "सुब्रह्मण्य अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/subrahmanya-ashtottara-sata-namavali.html"
  },
  {
    "text": "राघवेन्द्र अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/raghavendra-ashtottara-sata-namavali.html"
  },
  {
    "text": "लक्ष्मी नरसिंह अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/lakshmi-narasimha-ashtottara-sata-namavali.html"
  },
  {
    "text": "गायत्रि अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/gayatri-ashtottara-sata-namavali.html"
  },
  {
    "text": "अनन्त पद्मनाभ स्वामि अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/anantha-padmanabha-swamy-ashtottara-sata-namavali.html"
  },
  {
    "text": "गणेश षोडश नामावलि, षोडशनाम स्तोत्रम्",
    "href": "https://vignanam.org/devanagari/ganesha-shodasha-namavali,-shodashanama-stotram.html"
  },
  {
    "text": "गणपति गकार अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/ganapati-gakara-ashtottara-sata-namavali.html"
  },
  {
    "text": "दुर्गा अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/durga-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री विष्णु अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-vishnu-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री अनन्त पद्मनाभ अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-ananta-padmanabha-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री अय्यप्प अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-ayyappa-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री सत्यनारायण अष्टोत्तर शतनामावलिः",
    "href": "https://vignanam.org/devanagari/sri-satyanarayana-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री अन्नपूर्णा अष्टोत्तर शतनामावलिः",
    "href": "https://vignanam.org/devanagari/sri-annapurna-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री नरसिंह अष्टकम्",
    "href": "https://vignanam.org/devanagari/sri-narasimha-ashtakam.html"
  },
  {
    "text": "दत्तात्रेय अष्टोत्तर शत नामावली",
    "href": "https://vignanam.org/devanagari/dattatreya-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री विष्णु शत नामावलि (विष्णु पुराण)",
    "href": "https://vignanam.org/devanagari/sri-vishnu-sata-namavali-vishnu-purana.html"
  },
  {
    "text": "श्री विघ्नेश्वर अष्टोत्तरशत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-vighnesvara-ashtottara-sata-namavali.html"
  },
  {
    "text": "श्री शङ्कराचार्य अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sri-shankaracharya-ashtottara-sata-namavali.html"
  },
  {
    "text": "सूर्य अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/surya-ashtottara-sata-namavali.html"
  },
  {
    "text": "चन्द्र अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/chandra-ashtottara-sata-namavali.html"
  },
  {
    "text": "अङ्गारक अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/angaraka-ashtottara-sata-namavali.html"
  },
  {
    "text": "बुध अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/budha-ashtottara-sata-namavali.html"
  },
  {
    "text": "बृहस्पति अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/bruhaspati-ashtottara-sata-namavali.html"
  },
  {
    "text": "शुक्र अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sukra-ashtottara-sata-namavali.html"
  },
  {
    "text": "शनि अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/sani-ashtottara-sata-namavali.html"
  },
  {
    "text": "राहु अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/rahu-ashtottara-sata-namavali.html"
  },
  {
    "text": "केतु अष्टोत्तर शत नामावलि",
    "href": "https://vignanam.org/devanagari/ketu-ashtottara-sata-namavali.html"
  },
  {
    "text": "गोदा देवी अष्टोत्तर शत नामावलि",
